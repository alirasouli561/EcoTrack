{
  "name": "service-analytics",
  "version": "1.0.0",
  "description": "Service Analytics pour ECOTRACK",
  "main": "src/index.js",
  "scripts": {
    "test": "jest --passWithNoTests",
    "test:unit": "jest __tests__/unit --passWithNoTests",
    "test:coverage": "jest __tests__/unit __tests__/integration --coverage --passWithNoTests",
    "test:integration": "jest __tests__/integration --passWithNoTests",
    "test:e2e": "jest __tests__/e2e --passWithNoTests",
    "test:unit:html": "jest __tests__/unit --passWithNoTests && node scripts/junit-to-html.js unit",
    "test:integration:html": "jest __tests__/integration --passWithNoTests && node scripts/junit-to-html.js integration",
    "test:e2e:html": "jest __tests__/e2e --passWithNoTests && node scripts/junit-to-html.js e2e",
    "test:all:html": "jest --passWithNoTests && node scripts/junit-to-html.js all",
    "test:pyramid": "node scripts/test-pyramid-metrics.js",
    "test:report": "npm run test:all:html && npm run test:pyramid"
  },
  "keywords": [],
  "author": "SJMA",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "chart.js": "^4.5.1",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "kafkajs": "^2.2.4",
    "node-cache": "^5.1.2",
    "node-cron": "^3.0.3",
    "node-fetch": "^2.7.0",
    "nodemailer": "^8.0.1",
    "pdfkit": "^0.17.2",
    "pg": "^8.18.0",
    "pino": "^10.1.1",
    "pino-pretty": "^11.3.0",
    "prom-client": "^15.1.3",
    "redis": "^4.7.1",
    "simple-statistics": "^7.8.8",
    "socket.io": "^4.8.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "chartjs-node-canvas": "^5.0.0",

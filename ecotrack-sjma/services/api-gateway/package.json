{
    "name": "api-gateway",
    "version": "1.0.0",
    "description": "API Gateway for EcoTrack microservices",
    "main": "src/index.js",
    "scripts": {
        "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand",
        "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
        "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js __tests__/unit __tests__/integration --coverage --passWithNoTests",
        "test:integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js __tests__/integration --runInBand --passWithNoTests",
        "test:e2e": "node --experimental-vm-modules node_modules/jest/bin/jest.js __tests__/e2e --runInBand --passWithNoTests",
        "dev": "node src/index.js",
        "start": "node src/index.js"
    },
    "keywords": [
        "api-gateway",
        "microservices",
        "proxy"
    ],
    "author": "EcoTrack Team",
    "license": "ISC",
    "type": "module",
    "dependencies": {
        "axios": "^1.13.5",
        "cors": "^2.8.5",
        "dotenv": "^17.2.3",
        "express": "^5.2.1",
        "express-rate-limit": "^8.2.1",
        "helmet": "^8.1.0",
        "http-proxy-middleware": "^3.0.5",
        "jsonwebtoken": "^9.0.3",
        "morgan": "^1.10.1",
        "pg": "^8.20.0",
        "pino": "10.1.1",
        "pino-pretty": "^11.3.0",
        "prom-client": "^15.1.3",
        "redis": "^4.7.1",
        "swagger-ui-express": "^5.0.1"
    },
    "devDependencies": {
        "jest": "^29.7.0"
    }
}
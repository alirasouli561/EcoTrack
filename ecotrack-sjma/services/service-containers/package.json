{
  "name": "service-containers",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "test": "jest --runInBand",
    "test:unit": "jest __tests__/unit --runInBand",
    "test:coverage": "jest __tests__/unit __tests__/integration --coverage --runInBand --passWithNoTests",
    "test:integration": "jest __tests__/integration --runInBand || echo '⚠️ Integration tests require PostgreSQL'",
    "test:integration:skip": "SKIP_DB_TESTS=1 jest __tests__/integration --runInBand",
    "test:e2e": "jest __tests__/e2e --runInBand --detectOpenHandles --passWithNoTests",
    "test:socket": "jest __tests__/integration/socket.service.test.js --runInBand",
    "test:socket:integration": "jest __tests__/integration/socket.integration.test.js --runInBand",
    "test:socket:e2e": "jest __tests__/e2e/socket.e2e.test.js --runInBand --detectOpenHandles",
    "test:socket:client": "node __tests__/manual/socket-client-test.js",
    "test:socket:interactive": "node __tests__/manual/socket-interactive-test.js",
    "test:routes": "jest __tests__/integration/*-routes.test.js --runInBand",
    "test:security": "jest __tests__/integration/security.test.js --runInBand",
    "test:performance": "jest __tests__/e2e/performance.test.js --runInBand --detectOpenHandles",
    "test:scenarios": "jest __tests__/e2e/user-scenarios.test.js --runInBand --detectOpenHandles",
    "test-db": "node src/db/test-db.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jest-junit": "^16.0.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "pg": "^8.11.0",
    "pino": "10.1.1",
    "pino-pretty": "^10.3.1",
    "prom-client": "^15.1.3",
    "redis": "^4.7.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^9.0.1",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.2.2"
  }
}

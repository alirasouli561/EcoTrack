# ============================================================================
# SERVICE IOT - Variables d'environnement
# ============================================================================

# Serveur
APP_PORT=3013
NODE_ENV=development

# PostgreSQL
PGHOST=localhost
PGPORT=5432
PGUSER=ecotrack_user
PGPASSWORD=ecotrack_password
PGDATABASE=ecotrack

# MQTT Broker
MQTT_PORT=1883
MQTT_HOST=0.0.0.0

# MQTT TLS (Production)
# MQTT_TLS_ENABLED=true
# MQTT_TLS_KEY_PATH=./certs/server.key
# MQTT_TLS_CERT_PATH=./certs/server.crt
# MQTT_TLS_CA_PATH=./certs/ca.crt
# MQTT_TLS_REQUEST_CERT=false
# MQTT_TLS_REJECT_UNAUTHORIZED=false

# MQTT Authentification
# MQTT_AUTH_ENABLED=true
# MQTT_USERNAME=ecotrack
# MQTT_PASSWORD=ecotrack_mqtt_password

# Service Users (pour notifications)
USERS_SERVICE_URL=http://service-users:3010
USERS_SERVICE_TIMEOUT=5000

# Notifications
ALERT_NOTIFICATIONS_ENABLED=true

# Seuils d'alerte
ALERT_FILL_LEVEL_CRITICAL=90
ALERT_FILL_LEVEL_WARNING=75
ALERT_BATTERY_LOW=20
ALERT_TEMPERATURE_MIN=-10
ALERT_TEMPERATURE_MAX=60
ALERT_SENSOR_TIMEOUT_HOURS=24

# Logging
LOG_LEVEL=info

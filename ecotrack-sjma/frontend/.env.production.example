# ============================================================================
# FRONTEND - PRODUCTION ENVIRONMENT
# ============================================================================
# Copy this file to .env and update URLs for production

# Frontend URL (without trailing slash)
VITE_FRONTEND_URL=https://ecotrack.yourdomain.com

# API Gateway URL
VITE_API_URL=https://api.yourdomain.com

# Services URLs (optional, for direct access)
# VITE_USERS_URL=https://users.yourdomain.com
# VITE_CONTAINERS_URL=https://containers.yourdomain.com
# VITE_ROUTES_URL=https://routes.yourdomain.com

# Monitoring URLs (optional)
# VITE_GRAFANA_URL=https://grafana.yourdomain.com
# VITE_PROMETHEUS_URL=https://prometheus.yourdomain.com
# VITE_KAFKA_UI_URL=https://kafka-ui.yourdomain.com